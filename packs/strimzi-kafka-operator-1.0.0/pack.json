{
  "addonType": "system app",
  "annotations": {
    "commit_msg": "Run an Apache Kafka® cluster on Kubernetes with Strimzi",
    "source": "community",
    "contributor" : "spectrocloud"
  },
  "charts": [
    "charts/strimzi-kafka-operator-helm-3-chart-1.0.0.tgz"
  ],
  "cloudTypes": [
    "all"
  ],
  "displayName": "Strimzi Kafka",
  "layer":"addon",
  "name": "strimzi-kafka",
  "version": "1.0.0",
  "constraints": {
    "dependencies": [
      {
        "packName": "kubernetes",
        "layer": "k8s",
        "minVersion": "1.29",
        "maxVersion": "",
        "type": "optional"
      }
    ],
    "resources": [
      {
        "type": "cpu",
        "minLimit": 384
      },
      {
        "type": "memory",
        "minLimit": 200
      }
    ]
  }
}



